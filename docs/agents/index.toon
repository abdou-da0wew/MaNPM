---
url: /agents/index.toon
description: >-
  Main entry point for MaNPM documentation. Project overview, architecture,
  commands, palette, and key implementation patterns.
---

manpm:
  description: >
    The blazing-fast Go orchestrator for npm packages. Parallel tarball
    extraction, SHA512 verification, native module rebuild, .bin linking.
  language: Go 1.26+
  dependencies: stdlib only (zero external dependencies)
  module: manpm
  entrypoint: cmd/manpm/main.go
  router: buildRouter() / dispatch() — custom, no cobra/urfave
  config: manpm.config.toml — hand-rolled TOML parser

architecture:
  overview: >
    Install pipeline: lockfile parse -> dependency DAG (Kahn sort) ->
    level-based parallel extraction -> native rebuild chain -> .bin symlinking
  packages[12]:
    - binlink: .bin symlink management
    - buildmgr: Native package detection and rebuild chain
    - cache: JSON metadata cache for package resolutions
    - config: TOML configuration loader
    - extractor: Parallel tarball download, SHA512 verification, extraction
    - graph: Dependency graph, topological sort, cycle detection
    - intel: Project intelligence (explain, audit, doctor, map, entropy, sensei, compare, sandbox)
    - lockfile: package-lock.json v2/v3 parser
    - platform: OS/arch detection, memory-aware worker tuning
    - preflight: Pre-install validation
    - ui: ANSI terminal output

dataflow:
  - step: 1
    action: preflight.Run()
    output: "*preflight.Result"
  - step: 2
    action: lockfile.Parse()
    output: "*lockfile.LockfileV2"
  - step: 3
    action: graph.DependencyGraph.AddNode() + TopologicalSort()
    detail: Kahn's algorithm, cycle detection via DFS three-color
  - step: 4
    action: extractor.ExtractLevel()
    detail: >
      goroutine pool per level, HTTP GET + SHA512 via io.TeeReader,
      gzip + tar extract, integrity check, npm fallback on failure
  - step: 5
    action: buildmgr.RebuildAll() / RebuildSequential()
    strategies[4]: prebuild-install, node-gyp rebuild, npm rebuild, build-from-source
  - step: 6
    action: binlink.LinkAllPackages()

commands[14]{name,description,usage}:
  install,"Install all dependencies from lockfile",manpm install [options]
  add,"Add a package and show impact",manpm add <package> [options]
  explain,"Show why a package is installed",manpm explain <package>
  audit,"Run vulnerability analysis",manpm audit
  doctor,"Analyze project health",manpm doctor
  map,"Show ASCII dependency graph",manpm map
  entropy,"Show project chaos metrics",manpm entropy
  prune,"Scan source imports + graph transitive deps, identify unused packages",manpm prune [options]
  run,"Run a project script",manpm run <script>
  sandbox,"Show sandbox info for a package",manpm sandbox <package>
  compare,"Compare two installed packages",manpm compare <pkg1> <pkg2>
  sensei,"Full project architecture review",manpm sensei
  profile,"Manage installation profiles",manpm profile <subcommand> [name]
  pkgjson,"Manage package.json dependencies",manpm pkgjson <subcommand> [options]

aliases[15]{short,full}:
  i,install
  in,install
  inst,install
  r,run
  ad,add
  ex,explain
  au,audit
  doc,doctor
  pr,prune
  sb,sandbox
  cmp,compare
  pro,profile
  se,sensei
  ls,map
  pj,pkgjson

palette:
  description: Dark ANSI theme — 9 colors defined in pallet.json
  primary_colors[4]{name,hex,usage}:
    Orange,#E35A00,"Headers, logo accents, error icons"
    Golden,#FCA710,"Logo highlights, glowing accents"
    Cyan,#6CD0E5,"Info, subheaders, progress bars, gopher body"
    Coral,#E24F44,"Diagram arrows, warning accents"

implementation_patterns:
  zero_external_deps: >
    All packages use only Go stdlib. TOML parser is hand-written in
    pkg/config/toml.go. CLI router uses flag.FlagSet — no cobra/urfave.
  kahn_topological_sort: >
    Packages assigned to execution levels by in-degree. Same-level packages
    have no interdependencies and extract concurrently. Cycle = ErrCycleDetected.
  level_based_extraction: >
    goroutine pool per topological level. Each goroutine: HTTP GET tarball,
    stream through SHA512 hasher (io.TeeReader), decompress gzip, extract tar.
    Paths sanitized against Zip Slip via isPathSafe().
  retry_with_backoff: >
    Failed downloads retry up to MaxRetries with exponential backoff
    (attempt^2 seconds). Network errors retryable. Integrity failures not retryable.
  npm_fallback: >
    If all extraction attempts fail, falls back to npm install <pkg>@<version>
    for that specific package via fallbackInstall().
  platform_detection: >
    Detects OS/arch via runtime.GOOS + extra heuristics. Linux checks
    /system/build.prop for Android. Memory-aware worker capping via
    approxRAMGB(). Symlinks disabled on Windows unless MANPM_FORCE_SYMLINKS set.
  rebuild_chain[4]:
    - prebuild-install (prebuilt binary download via npx)
    - node-gyp rebuild (system node-gyp)
    - npm rebuild --foreground-scripts
    - npm rebuild --build-from-source
  heavyweight_detection: >
    Known heavy packages (canvas, sharp, cypress, etc.) detected by
    IsHeavyweightBinaryPkg(). Env vars set to skip unnecessary binary
    downloads via EnvForHeavyweightPkg().

testing_quirks[4]:
  - "pkg/intel tests: Explain/Audit/Compare/Sensei work against temp dirs, no live npm needed"
  - "pkg/buildmgr tests: create mock node_modules/ dirs with binding.gyp files"
  - "cmd/manpm tests: call dispatch() directly — --help handling is in main(), not dispatch()"
  - "Tests produce ANSI output to stdout (expected, not a failure)"
